[Unit]
Description=EMOM gallery manifest watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/emom/mediaserver
Environment=DEBOUNCE_SECONDS=5
ExecStart=/opt/emom/mediaserver/scripts/watch_manifest.sh /media/emom_2tb https://media.example.com /media/emom_2tb/.well-known/gallery-manifest.json gallery
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
