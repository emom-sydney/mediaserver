# Bind only to localhost; tusd posts hooks to this endpoint.
BIND_HOST=127.0.0.1
BIND_PORT=9100

# SQLite state for batch tracking.
STATE_DB_PATH=/var/lib/emom-upload-notify/state.db

# How often to check for completed batches.
FLUSH_INTERVAL_SECONDS=30

# If batch_total metadata is missing, treat a batch as done after this quiet period.
BATCH_QUIET_SECONDS=900

# SMTP settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# Email routing.
NOTIFY_FROM=uploads@media.emom.me
NOTIFY_TO=admin@emom.me
NOTIFY_SUBJECT_PREFIX=EMOM Upload

LOG_LEVEL=INFO

# Optional: finalize completed uploads from tus upload IDs into real filenames/paths.
# Use relative_path metadata when available, otherwise filename, otherwise upload_id.
FINALIZE_UPLOADS=false
TUSD_UPLOAD_DIR=/media/emom_2tb/incoming
FINAL_UPLOAD_DIR=/media/emom_2tb/new
KEEP_TUSD_INFO_FILES=false
